NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Hard-pinned CRM owner user_id. Must be a valid auth.users.id.
# Used by /api/intake (and Phase 2.1+ /api/contacts) to stamp user_id on
# rows inserted via the admin client (which bypasses RLS). Single-user
# system today. When/if multi-user is added, replace these env reads with
# session-derived ownership.
OWNER_USER_ID=

# Shared secret for internal API routes. Generated via:
#   openssl rand -hex 32
# Trusted callers (Claude Code skills, automation scripts) send it as
# `Authorization: Bearer <token>` to /api/contacts*. Browser/(app) pages
# do not call these routes -- they query Supabase directly via the
# session client. Treat this like a password: never commit, never paste
# into chat that gets logged externally.
INTERNAL_API_TOKEN=
