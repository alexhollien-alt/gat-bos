## Optional (deferred): the `/api/log-frontend-error` sink

`error.tsx` POSTs to `/api/log-frontend-error` which doesn't exist yet. To make the logging actually work, also land:

`~/crm/src/app/api/log-frontend-error/route.ts`:

```ts
import { NextResponse } from "next/server";
import { z } from "zod";
import { logError } from "@/lib/error-log";
import { checkRateLimit } from "@/lib/rate-limit/check";
import { extractIp } from "@/lib/rate-limit/extract-ip";

const Schema = z.object({
  path: z.string().max(2000),
  message: z.string().max(4000),
  digest: z.string().nullable(),
  stack: z.string().max(10000).nullable(),
});

export async function POST(request: Request) {
  const ip = extractIp(request.headers);
  const rl = await checkRateLimit(`ratelimit:fe-error:${ip}`, 30, 60);
  if (!rl.allowed) return NextResponse.json({ ok: true }, { status: 200 });

  const raw = await request.json().catch(() => null);
  const parsed = Schema.safeParse(raw);
  if (!parsed.success) return NextResponse.json({ ok: true }, { status: 200 });

  await logError("/api/log-frontend-error", parsed.data.message, {
    path: parsed.data.path,
    digest: parsed.data.digest,
    stack: parsed.data.stack?.slice(0, 4000),
  });
  return NextResponse.json({ ok: true });
}
```

Without this sink, `error.tsx`'s POST silently fails (acceptable -- the UI still shows). Adding the sink makes the logging real.

